# ============================================================
#  🛡️  Renegade AI Updater — .gitignore
#  作用：告诉 Git 哪些文件不要被上传到 GitHub
# ============================================================

# ----------------------------------------------------------
#  🔐 环境变量密钥（绝对不能提交！）
# ----------------------------------------------------------
.env

# ----------------------------------------------------------
#  🐍 Python 编译缓存（自动生成，不需要提交）
# ----------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# ----------------------------------------------------------
#  🗄️ 根目录下的旧缓存文件（已经在 reports/ 里持久化，这些不再需要）
#     注意：reports/paper_cache.json 不会被忽略！
# ----------------------------------------------------------
/paper_cache.json
/seen_ids.json
/newsapi_counter.json
/analysis_draft_cache.json
/search_results_cache.json

# ----------------------------------------------------------
#  📝 日志文件（每次运行自动生成，不用提交）
# ----------------------------------------------------------
radar.log
*.log
logs/

# ----------------------------------------------------------
#  🧪 虚拟环境文件夹（每个电脑不同，不能提交）
# ----------------------------------------------------------
venv/
env/
.venv/

# ----------------------------------------------------------
#  🔧 编辑器/系统临时文件
# ----------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ----------------------------------------------------------
#  🗃️ 雷达缓存文件（运行时自动生成，不要提交）
# ----------------------------------------------------------
docs/news/news_cache.json
docs/academic/academic_cache.json

# ----------------------------------------------------------
#  ✅ 允许提交 reports 文件夹里的所有报告和缓存
#     （这里什么也不写，就是告诉 Git：reports/ 不被忽略）
# ----------------------------------------------------------